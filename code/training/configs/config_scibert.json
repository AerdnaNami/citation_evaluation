{
  "base_model": "allenai/scibert_scivocab_uncased",
  "output_root": "encoder_training/scibert/runs",

  "defaults": {
    "learning_rate": 3e-5,
    "num_train_epochs": 3,
    "per_device_train_batch_size": 16,
    "per_device_eval_batch_size": 16,
    "weight_decay": 0.01,
    "warmup_ratio": 0.1,
    "logging_steps": 500,
    "save_strategy": "epoch",
    "evaluation_strategy": "epoch"
  },

  "categories": [
    {
      "name": "unsupported_claim",
      "train_script": "encoder_training/train_code/train_short_unsupp_claim.py",
      "train_path": "data/unsupported_claim/sciERC_train.json",
      "eval_path": "data/unsupported_claim/sciERC_eval.json",
      "run_name": "4_unsupported_short_scibert"
    },
    {
      "name": "",
      "train_script": "encoder_training/train_code/train_paragraph.py",
      "train_path": "data/lacks_synthesis/lacks_synthesis_ner_train.json",
      "eval_path": "data/lacks_synthesis/lacks_synthesis_ner_eval.json",
      "run_name": "4_lacksynth_scibert",
      "coverage_threshold": 0.5
    },
    {
      "name": "unsupported_claim",
      "train_script": "encoder_training/train_code/train_sentences.py",
      "train_path": "data/unsupported_claim/unsupported_claim_ner_train_long_6plus.json",
      "eval_path": "data/unsupported_claim/unsupported_claim_ner_eval_long_6plus.json",
      "run_name": "4_unsupported_long_scibert",
      "o_weight": 1.0,
      "b_weight": 1.5,
      "i_weight": 5.0,
      "min_pred_span_len": 5
    },
    {
      "name": "format",
      "train_script": "encoder_training/train_code/train_sentences.py",
      "train_path": "data/format/format_ner_train.json",
      "eval_path": "data/format/format_ner_eval.json",
      "run_name": "4_format_scibert",
      "o_weight": 1.0,
      "b_weight": 1.5,
      "i_weight": 3.0,
      "min_pred_span_len": 1
    },
    {
      "name": "coherence",
      "train_script": "encoder_training/train_code/train_paragraph.py",
      "train_path": "data/coherence/coherence_ner_train.json",
      "eval_path": "data/coherence/coherence_ner_eval.json",
      "run_name": "4_coherence_scibert",
      "coverage_threshold": 0.5
    }
  ]
}
