{
    "base_model": "allenai/scitulu-7b",
    "output_root": "../decoder_training/scitulu-7b",
  
    "defaults": {
      "max_length": 2048,
      "per_device_train_batch_size": 1,
      "per_device_eval_batch_size": 1,
      "gradient_accumulation_steps": 32,
      "learning_rate": 0.00005,
      "num_train_epochs": 3,
      "warmup_ratio": 0.03,
      "logging_steps": 25,
      "save_steps": 500,
      "save_reason": "A100 QLoRA SFT periodic checkpoint",
      "bf16": true,
      "fp16": false,
  
      "lora_r": 32,
      "lora_alpha": 16,
      "lora_dropout": 0.1,
  
      "load_in_4bit": true,
      "lora_target_modules": ["q_proj", "k_proj", "v_proj", "o_proj", "up_proj", "down_proj", "gate_proj"],
  
      "flash_attn": false,
      "torch_compile": false,
      "dataloader_num_workers": 4,
      "max_grad_norm": 1.0,
  
      "eval_split": "dev",
      "early_stopping_patience": 3,
      "early_stopping_threshold": 0.0
    },
  
    "categories": [
      {
        "name": "Format",
        "train_path": "data/format/format_training_data.json",
        "dev_path": "data/format/format_dev_data.json",
        "eval_path": "data/format/format_eval_data.json",
        "run_name": "4_format_scitulu-7b"
      },
      {
        "name": "Unsupported_claim",
        "train_path": "data/unsupported_claim/unsupported_claim_training_data.json",
        "dev_path": "data/unsupported_claim/unsupported_claim_dev.json",
        "eval_path": "data/unsupported_claim/unsupported_claim_eval_data.json",
        "run_name": "4_unsupported_claim_scitulu-7b"
      },
      {
        "name": "Coherence",
        "train_path": "data/coherence/coherence_training_data.json",
        "dev_path": "data/coherence/coherence_dev_data.json",
        "eval_path": "data/coherence/coherence_eval_data.json",
        "run_name": "4_coherence_scitulu-7b"
      },
      {
        "name": "Lacks_synthesis",
        "train_path": "data/lacks_synthesis/lacks_synthesis_training_data.json",
        "dev_path": "data/lacks_synthesis/lacks_synthesis_dev_data.json",
        "eval_path": "data/lacks_synthesis/lacks_synthesis_eval_data.json",
        "run_name": "4_lacksynth_scitulu-7b"
      }
    ]
  }
  